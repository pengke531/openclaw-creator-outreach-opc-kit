{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Creator Record v2",
  "type": "object",
  "required": [
    "canonicalId",
    "displayName",
    "region",
    "platform",
    "pageUrl",
    "channels",
    "dedupKeys",
    "status",
    "screeningDecision",
    "evidenceRefs"
  ],
  "properties": {
    "canonicalId": { "type": "string" },
    "displayName": { "type": "string" },
    "region": { "type": "string" },
    "platform": { "type": "string" },
    "pageUrl": { "type": "string" },
    "channels": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["platform", "handle"],
        "properties": {
          "platform": { "type": "string" },
          "handle": { "type": "string" },
          "url": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string" }
        }
      }
    },
    "dedupKeys": {
      "type": "object",
      "required": ["urls", "handles", "emails", "phones"],
      "properties": {
        "urls": { "type": "array", "items": { "type": "string" } },
        "handles": { "type": "array", "items": { "type": "string" } },
        "emails": { "type": "array", "items": { "type": "string" } },
        "phones": { "type": "array", "items": { "type": "string" } }
      }
    },
    "screeningMetrics": {
      "type": "object",
      "properties": {
        "followerCount": { "type": "number" },
        "recent10DayPostCount": { "type": "number" },
        "latestReelViews": { "type": "number" },
        "commentQualityScore": { "type": "number" }
      }
    },
    "evidenceRefs": { "type": "array", "items": { "type": "string" } },
    "screeningDecision": {
      "type": "string",
      "enum": ["screened_pass", "screened_fail", "evidence_gap", "dedup_rejected"]
    },
    "status": {
      "type": "string",
      "enum": [
        "discovered",
        "evidence_collecting",
        "evidence_gap",
        "screened_pass",
        "screened_fail",
        "dedup_rejected",
        "registered",
        "approved_for_outreach",
        "outreach_in_progress",
        "reply_received",
        "reply_pending_approval",
        "negotiation_active",
        "day4_review",
        "day4_stoploss",
        "day8_review",
        "qualified",
        "low_quality",
        "excluded",
        "closed"
      ]
    },
    "notes": { "type": "string" },
    "exclusionReason": { "type": "string" },
    "updatedAt": { "type": "string" }
    ,
    "registryView": {
      "type": "object",
      "properties": {
        "creator_name": { "type": "string" },
        "profile_url": { "type": "string" },
        "followers": { "type": "string" },
        "status": { "type": "string" },
        "updated_at": { "type": "string" }
      }
    },
    "instagramQualification": {
      "type": "object",
      "properties": {
        "geography_status": { "type": "string" },
        "persona_status": { "type": "string" },
        "followers_status": { "type": "string" },
        "geography_evidence": { "type": "string" },
        "persona_evidence": { "type": "string" },
        "followers_evidence": { "type": "string" }
      }
    }
  }
}
