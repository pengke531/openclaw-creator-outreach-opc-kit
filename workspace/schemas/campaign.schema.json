{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Campaign Record",
  "type": "object",
  "required": ["id", "name", "goal", "state", "targets"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "goal": { "type": "string" },
    "state": {
      "type": "string",
      "enum": [
        "discovered",
        "evidence_gap",
        "dedup_rejected",
        "manager_review",
        "owner_review",
        "approved_for_outreach",
        "contacted",
        "delivery_failed",
        "awaiting_reply",
        "reply_received",
        "reply_pending_approval",
        "reply_approved",
        "negotiation_in_progress",
        "day4_watch",
        "day4_stoploss",
        "day8_qualified",
        "day8_low_quality",
        "excluded",
        "closed"
      ]
    },
    "targets": { "type": "array", "items": { "type": "string" } },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "approvalLevel": { "type": "string" },
    "ownerNotes": { "type": "string" },
    "lastUpdatedAt": { "type": "string" }
  }
}
