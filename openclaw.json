{
  "_package": {
    "name": "creator-outreach-opc-agent-pack",
    "mode": "incremental-import",
    "version": "5.0"
  },
  "skills": {
    "load": {
      "extraDirs": [
        "__DOMAIN_ROOT__/workspace/skills/shared"
      ]
    }
  },
  "agents": {
    "defaults": {
      "workspace": "__DOMAIN_ROOT__/workspace",
      "memorySearch": {
        "enabled": true
      },
      "subagents": {
        "maxChildrenPerAgent": 4,
        "maxSpawnDepth": 2,
        "runTimeoutSeconds": 900,
        "archiveAfterMinutes": 60,
        "requireAgentId": true
      }
    },
    "list": [
      {
        "id": "main",
        "workspace": "__DOMAIN_ROOT__/workspace",
        "identity": {
          "name": "Creator Outreach Manager",
          "emoji": "MG"
        },
        "tools": {
          "profile": "messaging",
          "alsoAllow": [
            "read",
            "write",
            "exec",
            "subagents",
            "memory_search",
            "memory_get",
            "memory_store",
            "agents_list"
          ]
        },
        "subagents": {
          "allowAgents": [
            "wangcai",
            "laicai",
            "facai"
          ],
          "requireAgentId": true
        }
      },
      {
        "id": "wangcai",
        "workspace": "__DOMAIN_ROOT__/agents/wangcai",
        "identity": {
          "name": "Wangcai Discovery Operator",
          "emoji": "WC"
        },
        "tools": {
          "profile": "minimal",
          "alsoAllow": [
            "read",
            "write",
            "memory_search",
            "memory_get",
            "memory_store",
            "web_search",
            "web_fetch",
            "browser"
          ]
        }
      },
      {
        "id": "laicai",
        "workspace": "__DOMAIN_ROOT__/agents/laicai",
        "identity": {
          "name": "Laicai Outreach Operator",
          "emoji": "LC"
        },
        "tools": {
          "profile": "minimal",
          "alsoAllow": [
            "read",
            "write",
            "memory_search",
            "memory_get",
            "memory_store"
          ]
        }
      },
      {
        "id": "facai",
        "workspace": "__DOMAIN_ROOT__/agents/facai",
        "identity": {
          "name": "Facai ROI Analyst",
          "emoji": "FC"
        },
        "tools": {
          "profile": "minimal",
          "alsoAllow": [
            "read",
            "write",
            "memory_search",
            "memory_get",
            "memory_store"
          ]
        }
      }
    ]
  }
}
